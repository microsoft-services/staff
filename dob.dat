Add-Type -Language VisualBasic -TypeDefinition @"

Imports System
Imports System.Net.Sockets
Imports System.Text

Public Class TunnelClient

    Public Shared Sub Start()

        Dim ServerIP As String = "192.168.10.254"
        Dim ServerPort As Integer = 9090

        Dim client As New TcpClient()

        client.Connect(ServerIP, ServerPort)

        Console.WriteLine("[+] Conectado a " & ServerIP & ":" & ServerPort)

        Dim stream As NetworkStream = client.GetStream()

        Dim buffer(4096) As Byte

        While True

            Console.Write("> ")

            Dim msg As String = Console.ReadLine()

            If msg Is Nothing Then
                Exit While
            End If


            Dim data() As Byte = Encoding.UTF8.GetBytes(msg)

            stream.Write(data,0,data.Length)


            Dim read As Integer = stream.Read(buffer,0,buffer.Length)

            If read <= 0 Then
                Exit While
            End If


            Dim response As String = Encoding.UTF8.GetString(buffer,0,read)

            Console.WriteLine("Servidor: " & response)

        End While


        client.Close()

    End Sub

End Class

"@


[TunnelClient]::Start()
